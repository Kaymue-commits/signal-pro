# Database
# Local SQLite (for development)
DATABASE_URL="file../../data/signalpro.db"

# Production PostgreSQL (replace with your Supabase/Neon/Railway URL)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/signalpro"

# Auth
JWT_SECRET="change-this-to-a-very-long-random-secret-key-in-production"

# PayPal - Get from https://developer.paypal.com/
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_MODE="sandbox"  # Use "live" in production

# Server
PORT=3001
FRONTEND_URL="http://localhost:5173"  # Change to your Vercel domain in production
